vec4 dust(vec2 uv, bool dith)
{
  uint octaves = 8u;
  uv = dualfbm(uv, octaves, seed);

  float n_alpha = psfbm(uv * ceil(DUST_SIZE * 0.5) + uv * 2., octaves, seed);
